{
  "title": "Gateyes LLM Gateway",
  "uid": "gateyes-llm-gateway",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "LLM Requests RPS",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (surface, provider, result) (rate(gateway_llm_requests_total[5m]))",
          "legendFormat": "{{surface}} {{provider}} {{result}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "LLM Error Rate",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "(sum by (surface, provider) (rate(gateway_llm_requests_total{result!=\"success\"}[5m])))/(sum by (surface, provider) (rate(gateway_llm_requests_total[5m])))",
          "legendFormat": "{{surface}} {{provider}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request Latency p95",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, surface, provider) (rate(gateway_llm_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{surface}} {{provider}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Upstream Latency p95",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, surface, provider) (rate(gateway_llm_upstream_duration_seconds_bucket[5m])))",
          "legendFormat": "{{surface}} {{provider}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "TTFT p95",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, surface, provider) (rate(gateway_llm_time_to_first_token_seconds_bucket[5m])))",
          "legendFormat": "{{surface}} {{provider}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Token Throughput",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (provider, token_type) (rate(gateway_llm_tokens_total[5m]))",
          "legendFormat": "{{provider}} {{token_type}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Retries and Fallbacks",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(gateway_llm_retries_total[5m])",
          "legendFormat": "retry {{provider}}"
        },
        {
          "expr": "rate(gateway_llm_fallbacks_total[5m])",
          "legendFormat": "fallback {{provider}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Active Streams",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "gateway_llm_active_streams",
          "legendFormat": "{{surface}}"
        }
      ]
    }
  ]
}
