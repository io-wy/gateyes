# Gateway
GATEYES_CONFIG_PATH=configs/config.example.yaml
GATEYES_BOOTSTRAP_TEST_KEY=test-key-001
GATEYES_BOOTSTRAP_TEST_SECRET=test-secret
GATEYES_ADMIN_BOOTSTRAP_KEY=admin-key-001
GATEYES_ADMIN_BOOTSTRAP_SECRET=admin-secret-001

# Providers
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Database examples
SQLITE_DSN=gateyes.db
POSTGRES_DSN=postgres://gateyes:gateyes@postgres:5432/gateyes?sslmode=disable
MYSQL_DSN=gateyes:gateyes@tcp(mysql:3306)/gateyes?parseTime=true

# Optional webhook
GATEYES_ALERT_WEBHOOKURL=
GATEYES_ALERT_WEBHOOKSECRET=
