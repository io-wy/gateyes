{
  "server": {
    "listen_addr": ":8080",
    "read_timeout": "30s",
    "write_timeout": "30s",
    "idle_timeout": "120s"
  },
  "auth": {
    "enabled": false,
    "keys": ["replace-with-your-key"],
    "header": "Authorization",
    "query_param": "api_key",
    "skip_paths": ["/healthz", "/metrics", "/cache-stats"],
    "virtual_keys": {
      "vk-team-a": {
        "enabled": true,
        "description": "Team A pool",
        "providers": ["openai-primary", "openai-backup"],
        "default_provider": "openai-primary",
        "routing": {
          "strategy": "least-latency",
          "fallback": ["openai-backup"],
          "custom_rules": [
            {
              "name": "mini-to-backup",
              "description": "Route mini models to backup",
              "priority": 100,
              "enabled": true,
              "conditions": [
                {
                  "type": "model",
                  "field": "",
                  "operator": "contains",
                  "value": "gpt-4o-mini"
                }
              ],
              "action": {
                "type": "route",
                "provider": "openai-backup"
              }
            }
          ]
        }
      },
      "vk-team-b": {
        "enabled": true,
        "description": "Team B pool",
        "providers": ["openai-dr"],
        "default_provider": "openai-dr",
        "routing": {
          "strategy": "priority",
          "fallback": []
        }
      }
    }
  },
  "rate_limit": {
    "enabled": false,
    "backend": "memory",
    "redis_addr": "localhost:6379",
    "redis_password": "",
    "redis_db": 0,
    "redis_prefix": "gateyes",
    "tenant_header": "X-Tenant-ID",
    "default_completion_tokens": 256,
    "requests_per_minute": 300,
    "burst": 300,
    "by": "auth",
    "header": "",
    "skip_paths": ["/healthz", "/metrics", "/cache-stats"],
    "rules": [
      {
        "name": "rpm-user",
        "enabled": true,
        "dimensions": ["user"],
        "requests_per_minute": 300,
        "burst": 300
      },
      {
        "name": "tpm-user-model",
        "enabled": true,
        "dimensions": ["user", "model"],
        "tokens_per_minute": 120000
      },
      {
        "name": "tpm-tenant",
        "enabled": true,
        "dimensions": ["tenant"],
        "tenant_header": "X-Tenant-ID",
        "tokens_per_minute": 500000
      }
    ]
  },
  "quota": {
    "enabled": false,
    "backend": "memory",
    "redis_addr": "localhost:6379",
    "redis_password": "",
    "redis_db": 0,
    "redis_prefix": "gateyes",
    "tenant_header": "X-Tenant-ID",
    "default_completion_tokens": 256,
    "requests": 100000,
    "window": "24h",
    "by": "auth",
    "header": "",
    "tokens_per_day": 0,
    "tokens_per_month": 0,
    "skip_paths": ["/healthz", "/metrics", "/cache-stats"],
    "rules": [
      {
        "name": "daily-user",
        "enabled": true,
        "dimensions": ["user"],
        "tokens_per_day": 2000000
      },
      {
        "name": "monthly-tenant",
        "enabled": true,
        "dimensions": ["tenant"],
        "tenant_header": "X-Tenant-ID",
        "tokens_per_month": 50000000
      },
      {
        "name": "daily-user-model",
        "enabled": true,
        "dimensions": ["user", "model"],
        "tokens_per_day": 500000
      }
    ]
  },
  "metrics": {
    "enabled": true,
    "path": "/metrics",
    "namespace": "gateyes"
  },
  "cache": {
    "enabled": false,
    "backend": "memory",
    "ttl": "10m",
    "max_size": 104857600,
    "max_entries": 5000,
    "key_strategy": "full",
    "redis_addr": "localhost:6379",
    "redis_password": "",
    "redis_db": 0
  },
  "gateway": {
    "openai_path_prefix": "/v1",
    "provider_header": "X-Gateyes-Provider",
    "provider_query": "provider",
    "default_provider": "openai-primary",
    "agent_to_prod_prefix": "/prod",
    "agent_to_prod_upstream": "http://prod-gateway:9000",
    "routing": {
      "enabled": true,
      "strategy": "least-latency",
      "fallback": ["openai-backup", "openai-dr"],
      "health_check": {
        "enabled": true,
        "interval": "30s",
        "timeout": "5s",
        "unhealthy_threshold": 3,
        "healthy_threshold": 2
      },
      "retry": {
        "enabled": true,
        "max_retries": 2,
        "initial_delay": "100ms",
        "max_delay": "2s",
        "multiplier": 2.0
      },
      "circuit_breaker": {
        "enabled": true,
        "failure_threshold": 5,
        "success_threshold": 2,
        "timeout": "60s",
        "half_open_requests": 3
      },
      "custom_rules": [
        {
          "name": "Route gpt-4o-mini to backup",
          "description": "Small model traffic uses backup first",
          "priority": 200,
          "enabled": true,
          "conditions": [
            {
              "type": "model",
              "field": "",
              "operator": "contains",
              "value": "gpt-4o-mini"
            }
          ],
          "action": {
            "type": "route",
            "provider": "openai-backup"
          }
        },
        {
          "name": "Route gpt-4.1 to primary",
          "description": "High-end model traffic stays on primary",
          "priority": 150,
          "enabled": true,
          "conditions": [
            {
              "type": "model",
              "field": "",
              "operator": "regex",
              "value": "^gpt-4(\\.1|o)"
            }
          ],
          "action": {
            "type": "route",
            "provider": "openai-primary"
          }
        }
      ]
    }
  },
  "policy": {
    "enabled": false,
    "mode": "audit"
  },
  "providers": {
    "openai-primary": {
      "base_url": "https://api.openai.com",
      "ws_base_url": "wss://api.openai.com",
      "api_key": "sk-your-primary-key",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer",
      "headers": {}
    },
    "openai-backup": {
      "base_url": "https://api.openai.com",
      "ws_base_url": "wss://api.openai.com",
      "api_key": "sk-your-backup-key",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer",
      "headers": {}
    },
    "openai-dr": {
      "base_url": "https://api.openai.com",
      "ws_base_url": "wss://api.openai.com",
      "api_key": "sk-your-dr-key",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer",
      "headers": {}
    }
  }
}
