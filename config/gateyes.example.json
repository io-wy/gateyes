{
  "server": {
    "listen_addr": ":8080",
    "read_timeout": "30s",
    "write_timeout": "30s",
    "idle_timeout": "120s"
  },
  "auth": {
    "enabled": false,
    "keys": ["replace-with-your-key"],
    "header": "Authorization",
    "query_param": "api_key",
    "skip_paths": ["/healthz", "/metrics", "/stats"]
  },
  "metrics": {
    "enabled": true,
    "path": "/metrics",
    "namespace": "gateyes"
  },
  "cache": {
    "enabled": true,
    "backend": "memory",
    "ttl": "1h",
    "max_size": 104857600,
    "max_entries": 10000,
    "key_strategy": "full",
    "redis_addr": "localhost:6379",
    "redis_password": "",
    "redis_db": 0
  },
  "gateway": {
    "openai_path_prefix": "/v1",
    "provider_header": "X-Gateyes-Provider",
    "provider_query": "provider",
    "default_provider": "openai",
    "agent_to_prod_prefix": "/prod",
    "agent_to_mcp_prefix": "/mcp",
    "agent_to_prod_upstream": "http://prod-gateway:9000",
    "agent_to_mcp_upstream": "http://mcp-gateway:7000",
    "mcp_guard": {
      "enabled": true,
      "health_check": {
        "enabled": true,
        "interval": "30s",
        "timeout": "5s",
        "healthy_threshold": 2,
        "unhealthy_threshold": 3,
        "endpoint": "/health"
      },
      "circuit_breaker": {
        "enabled": true,
        "failure_threshold": 5,
        "success_threshold": 2,
        "timeout": "60s",
        "half_open_requests": 3
      },
      "timeout": {
        "connect": "5s",
        "read": "30s",
        "write": "30s",
        "idle": "90s"
      },
      "connection_pool": {
        "enabled": true,
        "max_connections": 10,
        "max_idle_time": "5m",
        "max_lifetime": "30m",
        "health_check_freq": "1m"
      },
      "anomaly_detection": {
        "enabled": true,
        "error_rate_threshold": 0.5,
        "latency_threshold": "10s",
        "consecutive_errors": 5,
        "alert_webhook": "https://your-webhook-url.com/alerts"
      },
      "fallback_behavior": {
        "strategy": "fail",
        "cache_ttl": "5m",
        "alternative_mcp": ""
      }
    },
    "routing": {
      "enabled": true,
      "strategy": "least-latency",
      "fallback": ["anthropic", "azure-openai"],
      "health_check": {
        "enabled": true,
        "interval": "30s",
        "timeout": "5s",
        "unhealthy_threshold": 3,
        "healthy_threshold": 2
      },
      "retry": {
        "enabled": true,
        "max_retries": 3,
        "initial_delay": "100ms",
        "max_delay": "5s",
        "multiplier": 2.0
      },
      "circuit_breaker": {
        "enabled": true,
        "failure_threshold": 5,
        "success_threshold": 2,
        "timeout": "60s",
        "half_open_requests": 3
      },
      "custom_rules": [
        {
          "name": "Route GPT-4 to Azure",
          "description": "Route all GPT-4 requests to Azure OpenAI for better performance",
          "priority": 100,
          "enabled": true,
          "conditions": [
            {
              "type": "body",
              "field": "",
              "operator": "contains",
              "value": "gpt-4"
            }
          ],
          "action": {
            "type": "route",
            "provider": "azure-openai"
          }
        },
        {
          "name": "Block expensive models for free users",
          "description": "Reject requests to expensive models from free tier users",
          "priority": 200,
          "enabled": true,
          "conditions": [
            {
              "type": "header",
              "field": "X-User-Tier",
              "operator": "equals",
              "value": "free"
            },
            {
              "type": "body",
              "field": "",
              "operator": "regex",
              "value": "(gpt-4|claude-opus)"
            }
          ],
          "action": {
            "type": "reject",
            "status": 403,
            "message": "Upgrade to access premium models"
          }
        },
        {
          "name": "Route embeddings to Cohere",
          "description": "Route embedding requests to cheaper provider",
          "priority": 75,
          "enabled": true,
          "conditions": [
            {
              "type": "path",
              "field": "",
              "operator": "contains",
              "value": "/embeddings"
            }
          ],
          "action": {
            "type": "route",
            "provider": "cohere"
          }
        }
      ]
    }
  },
  "policy": {
    "enabled": true,
    "mode": "enforce",
    "guardrails": {
      "enabled": true,
      "pii_detection": {
        "enabled": true,
        "redact": true,
        "patterns": [],
        "entity_types": ["email", "phone", "ssn", "credit_card"]
      },
      "content_filter": {
        "enabled": true,
        "block_profanity": false,
        "block_toxicity": false,
        "block_prompt_injection": true,
        "custom_blocklist": ["admin password", "system override"],
        "toxicity_threshold": 0.8
      },
      "response_validator": {
        "enabled": true,
        "max_tokens": 4096,
        "max_response_size": 1048576,
        "validate_json": false,
        "validate_structure": false,
        "required_fields": []
      },
      "anomaly_detection": {
        "enabled": true,
        "max_requests_per_minute": 100,
        "max_tokens_per_request": 8000,
        "suspicious_patterns": ["execute code", "run command"],
        "block_repeated_requests": true,
        "block_rapid_requests": true
      },
      "custom_rules": [
        {
          "name": "Block SQL Injection",
          "description": "Detect potential SQL injection attempts",
          "type": "request",
          "pattern": "'; DROP TABLE",
          "action": "block",
          "message": "Potential SQL injection detected"
        }
      ]
    }
  },
  "providers": {
    "openai": {
      "base_url": "https://api.openai.com",
      "ws_base_url": "wss://api.openai.com",
      "api_key": "sk-your-openai-key",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer",
      "headers": {
        "OpenAI-Organization": "org-placeholder"
      },
      "weight": 50,
      "input_cost": 10.0,
      "output_cost": 30.0
    },
    "anthropic": {
      "base_url": "https://api.anthropic.com",
      "api_key": "sk-ant-your-anthropic-key",
      "auth_header": "x-api-key",
      "auth_scheme": "",
      "headers": {
        "anthropic-version": "2023-06-01"
      },
      "weight": 30,
      "input_cost": 15.0,
      "output_cost": 75.0
    },
    "azure-openai": {
      "base_url": "https://your-resource.openai.azure.com",
      "api_key": "your-azure-key",
      "auth_header": "api-key",
      "auth_scheme": "",
      "headers": {
        "api-version": "2024-02-01"
      },
      "weight": 20,
      "input_cost": 10.0,
      "output_cost": 30.0
    },
    "cohere": {
      "base_url": "https://api.cohere.ai",
      "api_key": "your-cohere-key",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer",
      "weight": 10,
      "input_cost": 0.4,
      "output_cost": 1.2
    }
  }
}
